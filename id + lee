estimer_parametres_par_cohorte <- function(
  donnees_globales,
  annees_cibles,
  points_depart,  
  limites_inf,     
  limites_sup,     
  erreur_C
) {
  stopifnot(
    length(points_depart$alpha_min) == length(annees_cibles),
    length(points_depart$beta_min)  == length(annees_cibles),
    length(points_depart$gamma_min) == length(annees_cibles),
    length(points_depart$kappa_min) == length(annees_cibles)
  )

  res_list <- vector("list", length(annees_cibles))
  names(res_list) <- as.character(annees_cibles)

  for (i in seq_along(annees_cibles)) {
    annee <- annees_cibles[i]

    donnees_cible <- donnees_globales %>% filter(Year == annee)

    par_i   <- c(points_depart$alpha_min[i], points_depart$beta_min[i], points_depart$gamma_min[i], points_depart$kappa_min[i])
    lower_i <- c(limites_inf$alpha_min[i],   limites_inf$beta_min[i],   limites_inf$gamma_min[i], limites_inf$kappa_min[i])
    upper_i <- c(limites_sup$alpha_min[i],   limites_sup$beta_min[i],   limites_sup$gamma_min[i], limites_sup$kappa_min[i])

    res <- optim(
      par    = par_i,
      fn     = erreur_C,
      data   = donnees_cible,
      method = "L-BFGS-B",
      lower  = lower_i,
      upper  = upper_i
    )

    res_list[[as.character(annee)]] <- list(
      Year = annee,
      par = setNames(res$par, c("alpha", "beta", "gamma","kappa")),
      value = res$value
    )
  }

  res_list
}
