calculer_bornes <- function(model_lm, annee_cible, z_score) {
  pred <- predict(model_lm,
                  newdata = data.frame(Cohorte = annee_cible),
                  se.fit = TRUE)

  se_total <- sqrt(pred$se.fit^2 + summary(model_lm)$sigma^2)

  list(
    valeur = pred$fit,
    min = pred$fit - z_score * se_total,
    max = pred$fit + z_score * se_total
  )
}

calculer_bornes_exp <- function(model_lm, annee_cible, z_score) {
  pred <- predict(model_lm,
                  newdata = data.frame(Cohorte = annee_cible),
                  se.fit = TRUE)

  se_total <- sqrt(pred$se.fit^2 + summary(model_lm)$sigma^2)

  list(
    valeur = -exp(pred$fit),
    min = -exp(pred$fit - z_score * se_total),
    max = -exp(pred$fit + z_score * se_total)
  )
}

calculer_bornes_beta <- function(model_lm_beta, annee_cible, z_score) {
  pred <- predict(
    model_lm_beta,
    newdata = data.frame(Cohorte = annee_cible),
    se.fit = TRUE
  )

  se_total <- sqrt(pred$se.fit^2 + summary(model_lm_beta)$sigma^2)

  y_hat <- pred$fit
  y_min <- y_hat - z_score * se_total
  y_max <- y_hat + z_score * se_total

  beta_hat <- exp(-y_hat)
  beta_min <- exp(-y_max)  
  beta_max <- exp(-y_min)

  list(
    valeur = beta_hat,
    min = beta_min, 
    max = beta_max
  )
}


