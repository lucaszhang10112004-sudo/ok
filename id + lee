make_qhat_cond_from_lx <- function(data_year, S = 20) {
  lxS <- data_year$lx[data_year$Age == S][1]

  data_year %>%
    arrange(Age) %>%
    filter(Age >= S) %>%
    mutate(qhat_cond = 1 - lx / lxS) %>%
    select(Age, qhat_cond)
}


qcA <- function(t, alpha, beta, gamma, kappa) {
  t <- as.numeric(t)

  M <- alpha * t
  idx <- t > T

  if (any(idx)) {
    t_sup <- t[idx]

    if (abs(gamma) < 1e-8) {
      M[idx] <- alpha * t_sup + beta * (t_sup - T)
    } else {
      M[idx] <- alpha * t_sup +
        (beta / gamma) * (exp(gamma * (t_sup - T)) - 1)
    }
  }

  sqrt2M <- sqrt(2 * M / kappa)

  a1 <- (M - x_c) / sqrt2M
  a2 <- (M + x_c) / sqrt2M

  q <- 1 - pnorm(a1) + exp(-kappa * x_c) * pnorm(a2)
  return(q)
}

modele_C_cond <- function(t, S, alpha, beta, gamma, kappa) {
  F_t <- qcA(t, alpha, beta, gamma, kappa)
  F_S <- qcA(S, alpha, beta, gamma, kappa)
  return((F_t - F_S) / (1 - F_S))
}

erreur_C <- function(params, data) {
  a <- params[1]
  b <- params[2]
  g <- params[3]
  k <- params[4]

  if (a > 0 || b > 0 || k > 0) return(1e9)

  pred <- modele_C_cond(data$Age, AGE_MIN, a, b, g, k)

  if (any(is.nan(pred)) || any(is.infinite(pred))) return(1e9)

  sum((pred - data$qhat_cond)^2)
}

fit_modelC_while <- function(data, seuil = 0.1, max_tries = 10000, seed = 42) {
  set.seed(seed)

  lower <- c(alpha = -10, beta = -10, gamma = 0.001, kappa = -0.05)
  upper <- c(alpha =  -1, beta =  -1, gamma = 0.2,   kappa = -0.0001)

  tries <- 0

  while (tries < max_tries) {
    tries <- tries + 1

    p0 <- c(
      alpha = runif(1, lower["alpha"], upper["alpha"]),
      beta  = runif(1, lower["beta"],  upper["beta"]),
      gamma = runif(1, lower["gamma"], upper["gamma"]),
      kappa = runif(1, lower["kappa"], upper["kappa"])
    )

    res <- optim(
      par    = p0,
      fn     = erreur_C,
      data   = data,
      method = "L-BFGS-B",
      lower  = lower,
      upper  = upper
    )

    if (is.finite(res$value) && res$value < seuil) {
      res$par <- setNames(res$par, c("alpha", "beta", "gamma", "kappa"))
      res$tries <- tries
      return(res)
    }

    if (tries %% 100 == 0) {
      message("tries = ", tries, " | current value = ", res$value)
    }
  }

  stop("Aucun fit trouvé sous le seuil après ", max_tries, " essais.")
}


