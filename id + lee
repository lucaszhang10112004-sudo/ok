courbe_empirique_20_120 <- function(cohorte, rates_fc, ages_full = 20:120, S = 20) {
  
  years_dispo <- as.numeric(colnames(rates_fc))
  
  qc_full <- rep(NA, length(ages_full))
  
  ages_sub <- ages_full[ages_full >= S]
  years_cohorte <- cohorte + ages_sub
  
  ok <- years_cohorte %in% years_dispo
  
  ages_ok <- ages_sub[ok]
  years_ok <- years_cohorte[ok]
  
  if (length(ages_ok) > 0) {
    
    mx_vec <- sapply(seq_along(ages_ok), function(i) {
      rates_fc[as.character(ages_ok[i]), as.character(years_ok[i])]
    })
    
    qx_vec <- 1 - exp(-mx_vec)
    qx_vec[qx_vec < 0 | qx_vec > 1] <- NA
    
    qc_vec <- numeric(length(qx_vec))
    qc_vec[1] <- 0
    
    for (j in 2:length(qx_vec)) {
      qc_vec[j] <- 1 - prod(1 - qx_vec[1:(j - 1)])
    }
    
    # on place dans le vecteur complet
    idx <- match(ages_ok, ages_full)
    qc_full[idx] <- qc_vec
  }
  
  data.frame(
    Age = ages_full,
    qc_emp = qc_full
  )
}

comparer_20_120 <- function(cohorte, rates_fc, res_list) {
  
  ages_full <- 20:120
  
  # empirique
  df_emp <- courbe_empirique_20_120(cohorte, rates_fc, ages_full)
  
  # ID-SEM (INCHANGÉ)
  qc_idsem <- modele_C_cond(
