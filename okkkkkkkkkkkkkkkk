    if (is.finite(denom) && denom > 1e-10) {
      qx[j] <- (Fx[j] - Fx[j - 1]) / denom
    }
  }
  
  qx[qx <= 0 | qx >= 1] <- NA
  mx_id <- -log(1 - qx)
  
  data.frame(
    Cohorte = cohorte,
    Age = ages_ok,
    Year = years_ok,
