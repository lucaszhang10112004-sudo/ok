# ================================
# Reconstruction LC → qx → q_c(t|S)
# ================================

reconstruire_qc_LC <- function(mx_vec, ages, S = 20) {

  # 1. mx → qx
  qx <- 1 - exp(-mx_vec)

  # sécurité
  qx[qx < 0 | qx > 1] <- NA

  # 2. garder Age >= S
  idx <- ages >= S
  ages_sub <- ages[idx]
  qx_sub <- qx[idx]

  # 3. cumulée conditionnelle
  qc <- numeric(length(qx_sub))
  qc[1] <- 0

  for (j in 2:length(qx_sub)) {
    qc[j] <- 1 - prod(1 - qx_sub[1:(j - 1)])
  }

  return(data.frame(
    Age = ages_sub,
    qc = qc
  ))
}


