#esti des cohortes sous contraintes

estimer_parametres_par_cohorte <- function(
  donnees_globales,
  annees_cibles,
  points_depart,
  limites_inf,
  limites_sup
) {
  
  res_list <- vector("list", length(annees_cibles))
  names(res_list) <- as.character(annees_cibles)
  
  for (i in seq_along(annees_cibles)) {
    
    annee <- annees_cibles[i]
    
    donnees_cible <- donnees_globales %>%
      filter(Year == annee)
    
    par_i <- c(
      points_depart$alpha[i],
      points_depart$beta[i],
      points_depart$gamma[i],
      points_depart$kappa[i]
    )
    
    lower_i <- c(
      limites_inf$alpha[i],
      limites_inf$beta[i],
      limites_inf$gamma[i],
      limites_inf$kappa[i]
    )
    
    upper_i <- c(
      limites_sup$alpha[i],
      limites_sup$beta[i],
      limites_sup$gamma[i],
      limites_sup$kappa[i]
    )
    
    res <- optim(
      par    = par_i,
      fn     = erreur_C,
      data   = donnees_cible,
      method = "L-BFGS-B",
      lower  = lower_i,
      upper  = upper_i
    )
    
    res_list[[as.character(annee)]] <- list(
      Year = annee,
      par = setNames(res$par, c("alpha", "beta", "gamma", "kappa")),
      value = res$value
    )
  }
  
  return(res_list)
}

res_list <- estimer_parametres_par_cohorte(
