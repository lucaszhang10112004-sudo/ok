calculer_bornes <- function(model_lm, annee_cible, z_score) {
  
  pred <- predict(
    model_lm,
    newdata = data.frame(Cohorte = annee_cible),
    se.fit = TRUE
  )
  
  se_total <- sqrt(pred$se.fit^2 + summary(model_lm)$sigma^2)
  
  list(
    valeur = pred$fit,
    min = pred$fit - z_score * se_total,
    max = pred$fit + z_score * se_total
  )
}

#borne pour prediction

calculer_bornes_exp_neg <- function(model_lm, annee_cible, z_score) {
  
  pred <- predict(
    model_lm,
    newdata = data.frame(Cohorte = annee_cible),
    se.fit = TRUE
  )
  
  se_total <- sqrt(pred$se.fit^2 + summary(model_lm)$sigma^2)
  
  centre <- pred$fit
  borne_inf_log <- centre - z_score * se_total
  borne_sup_log <- centre + z_score * se_total
  
  list(
    valeur = -exp(centre),
    min = -exp(borne_sup_log),
    max = -exp(borne_inf_log)
  )
}

