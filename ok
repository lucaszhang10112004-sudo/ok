# ============================================================
# 2. PREPARATION DES DONNEES COHORTE
# ============================================================


charger_donnees_cohortes <- function(file_path, age_min = 20) {
  
  donnees_globales <- read.table(file_path, header = TRUE, na.strings = ".", skip = 2) %>%
    mutate(
      Age = parse_number(as.character(Age)),
      Year = as.numeric(Year),
      lx = as.numeric(lx)
    ) %>%
    filter(Age >= age_min) %>%
    group_by(Year) %>%
    mutate(
      l_ref = first(lx),
      qhat_cond = 1 - (lx / l_ref)
    ) %>%
    ungroup() %>%
    filter(!is.na(qhat_cond))
  
  return(donnees_globales)
}

# ============================================================
# 3. MODELE C
# ============================================================

# on prendd : 
# M(t) = alpha * t                      si t <= T
# M(t) = alpha * t + (beta/gamma)(exp(gamma(t-T)) - 1) si t > T

AGE_MIN <- 20
T <- 50
x_c <- 1000

calcul_M <- function(t, alpha, beta, gamma, T) {
  t <- as.numeric(t)

  M <- alpha * t
  idx <- t > T

  if (any(idx)) {
    t_sup <- t[idx]
    M[idx] <- alpha * t_sup +
      (beta / gamma) * (exp(gamma * (t_sup - T)) - 1)
  }

  return(M)
}

modele_qc <- function(t, alpha, beta, gamma, kappa, x_c, T) {
  M_t <- calcul_M(t, alpha, beta, gamma, T)

  terme_variance <- (2 * M_t) / kappa
  terme_variance[!is.finite(terme_variance) | terme_variance <= 1e-10] <- 1e-10

  racine <- sqrt(terme_variance)

  terme_1 <- pnorm((x_c + M_t) / racine)
  terme_2 <- exp(-kappa * x_c) * pnorm((-x_c + M_t) / racine)

  qc <- 1 - terme_1 + terme_2
  return(qc)
}

modele_cond <- function(t, S, alpha, beta, gamma, kappa, x_c, T) {
  F_t <- modele_qc(t, alpha, beta, gamma, kappa, x_c, T)
  F_S <- modele_qc(S, alpha, beta, gamma, kappa, x_c, T)

  denom <- 1 - F_S

  if (!is.finite(denom) || denom < 1e-10) {
    return(rep(1e12, length(t)))
  }

  q_cond <- (F_t - F_S) / denom
  return(q_cond)
}

erreur_C <- function(params, data) {
  alpha <- params[1]
  beta  <- params[2]
  gamma <- params[3]
  kappa <- params[4]

  if (alpha > 0 || beta > 0 || gamma < 0 || kappa > 0) {
    return(1e12)
  }

  pred <- modele_cond(
    t = data$Age,
    S = AGE_MIN,
    alpha = alpha,
    beta = beta,
    gamma = gamma,
    kappa = kappa,
    x_c = x_c,
    T = T
  )

  if (any(!is.finite(pred))) {
    return(1e12)
  }

  return(sum((pred - data$qhat_cond)^2))
}

fit_modele_C <- function(data_year, par_depart = c(-10, -5, 0.1, -0.002)) {
  optim(
    par = par_depart,
    fn = erreur_C,
    data = data_year,
    method = "Nelder-Mead"
  )
}

