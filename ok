library(tidyverse)
library(tibble)

# ============================================================
# 1. PARAMETRES GLOBAUX
# ============================================================

ANNEE_DEBUT <- 1900
ANNEE_FIN   <- 1930
PAS_TEMPS   <- 1

cohortes <- seq(ANNEE_DEBUT, ANNEE_FIN, PAS_TEMPS)

# ============================================================
# 2. TABLEAU DE STOCKAGE
# ============================================================

resultats_historique <- data.frame(
  Cohorte = cohortes,
  alpha = NA,
  beta  = NA,
  gamma = NA,
  kappa = NA,
  erreur = NA
)

# ============================================================
# 3. CALIBRAGE HISTORIQUE
# ============================================================

calibrer_historique_modele_C <- function(
  donnees_globales,
  cohortes,
  par_depart = c(-10, -5, 0.1, -0.002)
) {

  resultats_historique <- data.frame(
    Cohorte = cohortes,
    alpha = NA,
    beta  = NA,
    gamma = NA,
    kappa = NA,
    erreur = NA
  )

  start <- par_depart

  cat("Calibration historique en cours...\n")

  for (i in seq_along(cohortes)) {

    annee <- cohortes[i]

    data_year <- donnees_globales %>%
      filter(Year == annee)

    if (nrow(data_year) == 0) next

    res <- try(
      fit_modele_C(
        data_year = data_year,
        par_depart = start
      ),
      silent = TRUE
    )

    if (inherits(res, "try-error")) next

    resultats_historique[i, 2:5] <- res$par
    resultats_historique[i, 6]   <- res$value

    # hot start : on repart du résultat précédent
    start <- res$par
  }

  cat("Calibration terminée.\n")

  return(na.omit(resultats_historique))
}



resultats_historique <- calibrer_historique_modele_C(
  donnees_globales = donnees_globales,
  cohortes = cohortes,
  par_depart = c(-10, -5, 0.1, -0.002)
)

