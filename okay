# Fonction de répartition (CDF)
xc <- 1000
S <- 20

Delta <- function(t, ac, bc){
  return(exp(ac*t) + bc*t - 1)
}

modele_C_CDF <- function(t, ac, bc, sc, xc){
  return(pnorm(sqrt(sc/xc)*(Delta(t, ac, bc)-xc))-exp(2*sc*Delta(t, ac, bc))*pnorm(-sqrt(sc/xc)*(Delta(t, ac, bc)+xc)))
}

# Probabilité conditionnelle (Fonction utilisée pour le fit)
modele_C_cond <- function(t, S, alpha, beta, gamma, xc) {
  F_t <- modele_C_CDF(t, alpha, beta, gamma, xc)
  F_S <- modele_C_CDF(S, alpha, beta, gamma, xc)
  return((F_t - F_S) / (1 - F_S))
}

# Fonction d'erreur (Somme des carrés)
erreur_C <- function(params, data) {
  a <- as.numeric(params[1])
  b <- as.numeric(params[2])
  g <- as.numeric(params[3])

  if (a < 0 || b < 0 || g < 0) return(1e9)
  
  pred <- modele_C_cond(data$Age, 20, a, b, g, xc)
  return(sum((pred - data$F_empirique)^2))
}

