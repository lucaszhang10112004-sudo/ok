fit_modelC_while <- function(data, seuil = 0.1, max_tries = 10000, seed = 42) {
  set.seed(seed)

  lower <- c(alpha = 0.04, beta = 10, gamma = 0.005)
  upper <- c(alpha =  0.06, beta =  35, gamma = 0.01)

  tries <- 0

  while (tries < max_tries) {
    tries <- tries + 1

    p0 <- c(
      alpha = runif(1, lower["alpha"], upper["alpha"]),
      beta  = runif(1, lower["beta"],  upper["beta"]),
      gamma = runif(1, lower["gamma"], upper["gamma"])
    )
    
    res_keep <- 1
    res_par <- 0
    
    val <- erreur_C(p0, data_year)
    if (is.nan(val)) next

    res <- tryCatch(
      optim(
      par = p0,
      fn = erreur_C,
      data = data,
      method = "L-BFGS-B",
      lower = lower,
      upper = upper
        ),
      error = function(e) NULL
      )

    if (is.null(res)) next

    if (is.finite(res$value) && res$value < seuil) {
      res$par <- setNames(res$par, c("alpha", "beta", "gamma"))
      res$tries <- tries
      return(res)
    }
    
    if (res_keep > res$value){
      res_keep <- res$value
      res_par <- res$par
    }

    if (tries %% 100 == 0) {
      message("tries = ", tries, " | current value = ", res_keep,  "pour les paramètres", res_par)
    }
  }

  cat("Aucun fit trouvé sous le seuil après ", max_tries, " essais.", "le meilleur fit trouvé est ", res_keep, "pour les paramètres ", res_par)
  return(list(par = res_par, value = res_keep))
}

