# B. Fonction utilitaire pour calculer les bornes (évite la répétition de code)
calculer_bornes <- function(model_lm, annee_cible, z_score, pred) {
  pred <- predict(model_lm, newdata = data.frame(Cohorte = annee_cible), se.fit = TRUE)
  
  # Incertitude totale = Erreur modèle + Bruit historique (Sigma)
  se_total <- sqrt(pred$se.fit^2 + summary(model_lm)$sigma^2)
  
  list(
    valeur = pred$fit,
    min = pred$fit - z_score * se_total, # max(0) pour éviter le négatif
    max = pred$fit + z_score * se_total
  )
}

# Cas beta : modèle sur y = -log(beta), donc IC sur y puis transformation beta = exp(-y)
calculer_bornes_beta <- function(model_lm_beta, annee_cible, z_score) {
  pred <- predict(
    model_lm_beta,
    newdata = data.frame(Cohorte = annee_cible),
    se.fit = TRUE
  )

  se_total <- sqrt(pred$se.fit^2 + summary(model_lm_beta)$sigma^2)

  y_hat <- pred$fit
  y_min <- y_hat - z_score * se_total
  y_max <- y_hat + z_score * se_total

  beta_hat <- exp(-y_hat)
  beta_min <- exp(-y_max)   # inversion (car exp(-y) décroît)
  beta_max <- exp(-y_min)

  list(
    valeur = beta_hat,
    min = beta_min,  # <- vectorisé
    max = beta_max
  )
}

